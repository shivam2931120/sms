# Environment variables for SMS
# Copy this to .env locally and add the same values in Vercel Project Settings.

# Security
SECRET_KEY=replace-with-a-long-random-secret

# Supabase PostgreSQL
# Use the Supabase Session Pooler or direct connection string.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Alternative Supabase connection
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Flask settings
FLASK_ENV=production
FLASK_DEBUG=0

# Demo login cards
SHOW_DEMO_CREDENTIALS=true

# SMTP email placeholders
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=

# Razorpay placeholders
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR
